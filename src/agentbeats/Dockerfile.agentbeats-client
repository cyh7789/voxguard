FROM ghcr.io/astral-sh/uv:python3.12-trixie AS python-deps

RUN adduser agentbeats
USER agentbeats
RUN mkdir -p /home/agentbeats/.cache/uv
WORKDIR /home/agentbeats/app

COPY --chown=agentbeats:agentbeats pyproject.toml uv.lock README.md ./

RUN \
    --mount=type=cache,target=/home/agentbeats/.cache/uv,uid=1000 \
    uv sync --frozen --no-install-project --no-dev

FROM ghcr.io/astral-sh/uv:python3.12-trixie

RUN adduser agentbeats
USER agentbeats
WORKDIR /home/agentbeats/app

COPY --from=python-deps --chown=agentbeats:agentbeats /home/agentbeats/app/.venv .venv
COPY --chown=agentbeats:agentbeats src src

ENV PYTHONPATH=/home/agentbeats/app/src

ENTRYPOINT [".venv/bin/python", "src/agentbeats/client_cli.py"]
