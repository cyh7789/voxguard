FROM ghcr.io/astral-sh/uv:python3.12-trixie

RUN adduser agentbeats
USER agentbeats
RUN mkdir -p /home/agentbeats/.cache/uv
WORKDIR /home/agentbeats/app

COPY pyproject.toml uv.lock README.md ./
COPY src src

# Copy CAR-bench before uv sync because the evaluator extra uses it as a local path dependency.
# Note: Run './scripts/setup_car_bench.sh' locally before building to include the dependency in the build context.
COPY --chown=agentbeats:agentbeats third_party third_party

# Clean up any local build artifacts
RUN find third_party -type d -name "*.egg-info" -exec rm -rf {} + || true
RUN find third_party -type d -name "__pycache__" -exec rm -rf {} + || true

RUN \
    --mount=type=cache,target=/home/agentbeats/.cache/uv,uid=1000 \
    uv sync --no-editable --no-dev --extra car-bench-evaluator

ENTRYPOINT ["uv", "run", "src/green_car_bench_agent/server.py"]
CMD ["--host", "0.0.0.0"]
EXPOSE 8081
