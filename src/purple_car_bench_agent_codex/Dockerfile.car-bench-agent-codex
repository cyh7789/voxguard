FROM ghcr.io/astral-sh/uv:python3.12-trixie AS python-deps

RUN adduser agentbeats
USER agentbeats
RUN mkdir -p /home/agentbeats/.cache/uv
WORKDIR /home/agentbeats/app

COPY --chown=agentbeats:agentbeats pyproject.toml uv.lock README.md ./
COPY --chown=agentbeats:agentbeats third_party third_party

RUN \
    --mount=type=cache,target=/home/agentbeats/.cache/uv,uid=1000 \
    uv sync --frozen --no-install-project --no-dev --extra car-bench-agent-codex

FROM node:22-bookworm-slim AS codex-cli
ARG CODEX_NPM_PACKAGE="@openai/codex@0.130.0"
RUN npm install -g --include=optional "${CODEX_NPM_PACKAGE}"

FROM ghcr.io/astral-sh/uv:python3.12-trixie

RUN apt-get update \
    && apt-get install -y --no-install-recommends bubblewrap \
    && rm -rf /var/lib/apt/lists/*

COPY --from=codex-cli /usr/local/bin/node /usr/local/bin/node
COPY --from=codex-cli /usr/local/lib/node_modules /usr/local/lib/node_modules
RUN ln -sf /usr/local/lib/node_modules/@openai/codex/bin/codex.js /usr/local/bin/codex

RUN adduser agentbeats
USER agentbeats
RUN mkdir -p /home/agentbeats/.cache/uv /home/agentbeats/.codex /home/agentbeats/codex-work
WORKDIR /home/agentbeats/app

COPY --from=python-deps --chown=agentbeats:agentbeats /home/agentbeats/app/.venv .venv
COPY --chown=agentbeats:agentbeats src src

ENV CODEX_HOME=/home/agentbeats/.codex
ENV CODEX_WORKDIR=/home/agentbeats/codex-work
ENV CODEX_APP_SERVER_CMD="codex app-server --listen stdio://"
ENV PYTHONPATH=/home/agentbeats/app/src

ENTRYPOINT [".venv/bin/python", "src/purple_car_bench_agent_codex/server.py"]
CMD ["--host", "0.0.0.0"]
EXPOSE 8080
